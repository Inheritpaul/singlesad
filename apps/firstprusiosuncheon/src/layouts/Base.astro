---
import 'pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css';
import '../styles/global.css';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>순천 푸르지오 더 퍼스트 | 첫 푸르지오, 순천의 중심이 되다</title>
    <meta name="description" content="첫 푸르지오, 순천의 중심이 되다. 지금 분양 받고 역대급 혜택을 받아보세요." />

    <!-- Open Graph -->
    <meta property="og:title" content="순천 푸르지오 더 퍼스트" />
    <meta property="og:description" content="첫 푸르지오, 순천의 중심이 되다. 지금 분양 받고 역대급 혜택을 받아보세요." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://firstprusiosuncheon.co.kr" />
    <meta property="og:image" content="https://firstprusiosuncheon.co.kr/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="순천 푸르지오 더 퍼스트" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="순천 푸르지오 더 퍼스트" />
    <meta name="twitter:description" content="첫 푸르지오, 순천의 중심이 되다. 지금 분양 받고 역대급 혜택을 받아보세요." />
    <meta name="twitter:image" content="https://firstprusiosuncheon.co.kr/og-image.png" />

    <!-- Favicons + manifest -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div class="pt-[100px] md:pt-[60px]">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 160px;
  }
  @media (min-width: 768px) {
    html { scroll-padding-top: 120px; }
  }
  body {
    font-family: 'Pretendard Variable', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    font-weight: 400;
    color: #434143;
    background: #ffffff;
  }
</style>
