<style>
  /* section07 PRIDE6 grid — inset dividers (30px top/bottom on vertical, 30px left/right on horizontal) */
  .pride-card { position: relative; }
  .pride-card::after {
    content: '';
    position: absolute;
    top: 30px;
    bottom: 30px;
    right: 0;
    width: 1.5px;
    background: #434143;
  }
  .pride-card::before {
    content: '';
    position: absolute;
    left: 30px;
    right: 30px;
    bottom: 0;
    height: 1.5px;
    background: #434143;
  }
  /* Mobile (2-col): hide right divider on even cards (last col), bottom on last row (cards 5,6) */
  .pride-card:nth-child(2n)::after { display: none; }
  .pride-card:nth-child(n+5)::before { display: none; }
  /* Desktop (≥768, 3-col): re-show right on even cards, hide on 3n (last col); hide bottom on cards 4-6 */
  @media (min-width: 768px) {
    .pride-card:nth-child(2n)::after { display: block; }
    .pride-card:nth-child(3n)::after { display: none; }
    .pride-card:nth-child(n+4)::before { display: none; }
  }

  /* section08 type-detail horizontal scroll galleries — visible thin scrollbar as scroll indicator */
  .gallery-scroll {
