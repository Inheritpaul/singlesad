---
// codevent — 마닐라 COD 대박 프로모션
// Hand-built rebuild of the codevent.co.kr landing page. All copy is real,
// selectable HTML text (the original shipped every string as flattened SVG);
// the type hierarchy lives in src/styles/global.css (@theme --text-* tokens).
// Raster imagery loads from R2 (codevent/ prefix); the only local SVGs are
// the six step-progress rings and the red discount arrow.
import "pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css";
import "../styles/global.css";

const ASSET_BASE = import.meta.env.PUBLIC_ASSETS_BASE_URL;
const img = (name: string) => `${ASSET_BASE}/codevent/${name}.webp`;

const title = "마닐라 COD 대박 프로모션";
const siteUrl = "https://www.codevent.co.kr/";

const KAKAO_QR = "https://qr.kakao.com/talk/qdHvdBS9RxXfVO7VbZQK.a.fDwg-";
const KAKAO_OPEN = "https://open.kakao.com/o/s3SKR3fi";

// 프로모션 참여 방법 — six steps (bold spans preserved from the original)
const steps = [
  {
    icon: "step-01",
    html: `카카오톡 아이디 <strong>codevent</strong>를 친구 추가하고 일정 확인을 받습니다. (상담시간 오전 10시 ~ 오후 6시 / 긴급 24시간)`,
  },
  {
    icon: "step-02",
    html: `방문 날짜와 비행기 스케줄을 공유해 주시면, 해당 일자에 호텔방 예약이 가능한지 먼저 확인해 드립니다. (26년 4월 이벤트 종료)`,
  },
  {
    icon: "step-03",
    html: `컨피넘버(예약번호)를 전달받으신 후 입금을 진행하시면 됩니다.`,
  },
  {
    icon: "step-04",
    html: `해당 날짜에 방문하시면 편도픽업 차량이 대기하고 있습니다. COD 직원과 미팅하시면 됩니다.`,
  },
  {
    icon: "step-05",
    html: `해당 날짜에 방문하셔서 호텔 로비에 짐을 맡기신 후, 게임장 안에 있는 메인데스크에서 “멜코클럽 멤버십 카드”를 발급받으시면 됩니다. (여권 필요)`,
  },
  {
    icon: "step-06",
    html: `<strong>‘멜코클럽 멤버십 카드’를 발급</strong>받으신 후, 호텔 로비에서 체크인을 진행하시면 됩니다.`,
  },
];

// COD의 즐길거리들 — four cards
const funCards = [
  {
    pill: "드림플레이",
    image: "07_fun_dreamplay",
    caption: "아이들이 맘 놓고 놀 수 있는 모험 가득한 어드벤처",
  },
  {
    pill: "럭셔리 풀장",
    image: "07_fun_pool",
    caption: "누와호텔, 노부호텔, 하얏트호텔 각각 수영장을 갖추고 있어 여유롭게 즐기실 수 있습니다.",
  },
  {
    pill: "다양한 레스토랑",
    image: "07_fun_restaurant",
    caption:
      "현지식, 한식, 양식, 일식 등 다양한 레스토랑과 한국 편의점까지 입점해 있어 취향대로 즐기실 수 있습니다.",
  },
  {
    pill: "쇼핑거리",
    image: "07_fun_shopping",
    caption: "다양한 샵이 입점해 있어 쇼핑을 즐기실 수 있습니다.",
  },
];

// Q&A — five items (bold lead spans preserved from the original)
const qna = [
  {
    q: "가격이 너무 저렴한데 사기 아닌가요?",
    a: `<strong>마닐라 시티오브드림이 공식 파트너로 진행</strong>하는 프로모션으로 안심하셔도 됩니다.<br />당사에서 고객 유치를 위해 직접 진행하는 프로모션으로, 일정 기간 이후 해당 프로모션은 종료될 수 있습니다.`,
  },
  {
    q: "해당 상품을 언제나 동일한 가격에 이용할 수 있는 건가요?",
    a: `멜코클럽 미가입자, 혹은 6개월 이상 해당 멤버십을 사용하지 않으신 가입자분들은 해당 프로모션을 이용하실 수 있습니다.<br /><br />이에 해당되지 않는 분들도 멜코카드에 포인트를 적립받아 혜택을 누리실 수 있습니다. 누적 포인트가 일정 수준 이상이 되면 누와호텔 혹은 노부호텔을 무료로 이용하실 수도 있습니다. 보다 자세한 내용은 카카오톡 채널을 통해 문의해 주시기 바랍니다.`,
  },
  {
    q: "멜코클럽 포인트는 어떻게 쌓나요?",
    a: `마닐라 시티오브드림(COD) 안에 있는 게임을 이용하시면 포인트를 쌓으실 수 있습니다.<br />단, COD 이외의 게임장을 통한 포인트 적립은 불가하니, 게임 이용 전 참고해 주시기 바랍니다.`,
  },
  {
    q: "돈을 많이 써야만 포인트가 적립되나요?",
    a: `그렇지 않습니다.<br />포인트 적립은 이용 금액보다 게임 플레이 시간의 영향을 많이 받습니다.<br />따라서 적은 금액이더라도 오랜 시간 게임을 즐기신다면 포인트를 꾸준히 적립하실 수 있습니다.`,
  },
  {
    q: "궁금한 게 많은데 어디로 문의하면 되나요?",
    a: `궁금하신 내용은 카카오톡 아이디 CODEVENT를 통해 문의해 주시면 자세하게 설명드리고 있습니다. 많은 관심과 문의 부탁드립니다.`,
    cta: true,
  },
];

// Footer legal rows: [label, value] pairs flow inline with ㅣ separators
const footerItems: [string, string][] = [
  ["회사명", "(주)싱글즈키친"],
  ["대표", "김인규"],
  ["대표전화", "02-6956-2671"],
  ["주소", "08389 서울특별시 구로구 디지털로 26길 5 (구로동) 에이스 하이앤드 타워1차 7층 706호"],
  ["사업자 등록번호", "836-81-01858"],
  ["통신판매업 신고번호", "2021-서울구로-1116호 [사업자정보확인]"],
  ["건강기능식품 영업신고증 신고번호", "양천구-제2023-0097034"],
  ["개인정보관리책임자", "김인규(ecb@singles-kitchen.co.kr)"],
];

const melcoP2 = `멜코클럽은 티어(등급) 업그레이드, 포인트 멀티플라이어(적립 배수) 등 멤버십 리워드를 강화해 운영하고 있으며, 멤버 전용 오퍼가 제공됩니다. 모바일에서는 Melco Club 앱을 통해 회원 상태/혜택 확인, 맞춤형 프로모션 오퍼, 호텔 및 레스토랑 예약까지 한 번에 관리할 수 있어 여행 일정이 훨씬 편해집니다.`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <meta name="description" content="마닐라 시티오브드림 누와 호텔 또는 노부 호텔 + 편도픽업, 3박 169,000원 / 2박 129,000원 대박 프로모션" />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
  </head>
  <body>
    <!-- Floating KakaoTalk consult button -->
    <a
      href={KAKAO_OPEN}
      target="_blank"
      rel="noopener"
      class="fixed bottom-6 right-4 z-50 block w-[120px] transition-transform duration-300 hover:scale-105 md:bottom-8 md:right-6 xl:w-[150px]"
      aria-label="카카오톡 상담하기"
    >
      <img src={img("00_kakao_float_btn")} alt="카카오톡 상담" class="h-auto w-full" />
    </a>

    <!-- ─── Hero ──────────────────────────────────────────────────── -->
    <header class="relative overflow-hidden bg-black">
      <img
        src={img("01_hero_header")}
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-top"
      />
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(43,54,160,0.85)_0%,rgba(24,32,110,0.45)_34%,rgba(0,0,0,0.25)_62%,#000_100%)]"
      >
      </div>

      <div class="relative mx-auto w-full max-w-[1120px] px-5 pb-16 pt-8 md:px-10 md:pb-24 xl:pb-32">
        <a
          href={KAKAO_QR}
          target="_blank"
          rel="noopener"
          class="hidden rounded-full border border-white/80 px-5 py-2 text-caption font-semibold tracking-wide transition-colors hover:bg-white/10 md:inline-block"
        >
          프로모션 참여하기
        </a>

        <img
          src={img("01_logo_manilacod")}
          alt="City of Dreams Manila"
          class="mx-auto mt-2 w-[108px] md:mt-0"
        />

        <div class="mt-10 text-center md:mt-14">
          <h1 class="text-h2 font-light tracking-[0.06em] text-white/95">마닐라 시티오브드림</h1>
          <p class="mt-2 text-lead">
            시티오브드림 누와 호텔 또는 노부 호텔 2박/3박
            <strong class="font-bold">약 70% 이상 할인 혜택</strong>
          </p>
          <p class="mt-5 text-h2 font-bold">대박 프로모션</p>
          <div class="mt-4 flex flex-col items-center gap-3 md:flex-row md:items-stretch md:justify-center md:gap-4">
            {
              [
                ["3박", "900,000원", "169,000원"],
                ["2박", "600,000원", "129,000원"],
              ].map(([nights, was, price]) => (
                <div class="w-full max-w-[360px] rounded-2xl border border-white/20 bg-white/10 px-8 py-5 backdrop-blur-sm md:w-auto md:max-w-none">
                  <p class="text-h2 font-bold text-white/90">{nights}</p>
                  <p class="text-h2 font-semibold tabular-nums text-white/50">
                    <s>{was}</s>
                  </p>
                  <p class="mt-1 text-display font-extrabold leading-none tabular-nums tracking-tight">{price}</p>
                </div>
              ))
            }
          </div>
          <p class="mt-6 text-lead font-light">
            시오디 마닐라 카카오톡 <strong class="font-extrabold">“codevent”</strong>로 문의
          </p>
          <p class="mt-1 text-caption text-white/80">
            (카카오톡 상담 후 방문하시는 날짜에 호텔방 확인 후 결제 진행)
          </p>
          <a
            href={KAKAO_QR}
            target="_blank"
            rel="noopener"
            class="mt-8 inline-block rounded-full border border-white px-8 py-3 text-body font-semibold transition-colors hover:bg-white/10"
          >
            프로모션 참여하기
          </a>
        </div>

        <!-- 참여 가능 고객 -->
        <div class="reveal mx-auto mt-20 max-w-[600px] rounded-2xl border border-white/15 bg-black/35 p-6 text-caption leading-relaxed text-white backdrop-blur-sm md:mt-32 md:p-8">
          <p class="font-bold">프로모션 참여 가능 고객</p>
          <p>- 시티오브드림 (CITY OF DREAM) 마닐라 신규 방문 고객</p>
          <p>- 멤버십 가입(멜코클럽) 가입자 중 6개월 이상 방문하지 않으신 고객님 대상!</p>
          <p>- 멤버십 가입(멜코클럽) 가입자 중 6개월 미만 고객도 상담을 통해 진행 가능</p>
          <p class="mt-4">
            상담전화 : <strong class="text-body font-bold">02-6956-2671</strong>
            (상담시간 오전 10시 ~ 오후 5시 / 문의 전화가 많을 시 지연될 수 있습니다.)
          </p>
          <p>필요서류 : 여권사진 + 항공권 (예약 시)</p>
        </div>
      </div>
    </header>

    <!-- ─── CITY OF DREAM banner strip ────────────────────────────── -->
    <div class="overflow-hidden bg-black" aria-hidden="true">
      <picture>
        <source media="(min-width: 1280px)" srcset={img("02_banner_marquee_d")} />
        <source media="(min-width: 768px)" srcset={img("02_banner_marquee_t")} />
        <img src={img("02_banner_marquee_m")} alt="" class="w-full" />
      </picture>
    </div>

    <!-- ─── Intro: 마닐라 시티오브드림 ────────────────────────────── -->
    <section class="bg-black">
      <div class="relative">
        <img
          src={img("02_intro_cod_night")}
          alt="City of Dreams Manila 전경"
          class="aspect-[3/4] w-full object-cover md:aspect-[4/3] xl:aspect-[5/4]"
        />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,#000_4%,rgba(0,0,0,0.55)_36%,rgba(0,0,0,0)_75%)]"></div>
        <div class="reveal absolute inset-x-0 top-[10%] px-5 text-center md:top-[12%]">
          <p class="text-eyebrow font-bold">꿈이 현실이 되는 도심 속 리조트</p>
          <h2 class="mt-1 text-h1 font-extrabold">마닐라 시티오브드림</h2>
          <p class="mt-3 text-lead font-light text-white/90">당신의 꿈같은 휴가가 기다립니다!</p>
        </div>
      </div>
    </section>

    <!-- ─── 혜택 01 — 2대 럭셔리 호텔 ─────────────────────────────── -->
    <section class="bg-[linear-gradient(180deg,#000_0%,#0e1440_30%,#0a0f2e_55%,#0d0d0d_100%)]">
      <div class="mx-auto w-full max-w-[1120px] px-5 py-24 text-center md:px-10 md:py-40">
        <span
          class="reveal inline-block rounded-full bg-brand px-5 py-1.5 text-caption font-bold"
        >
          혜택 01
        </span>
        <h2 class="reveal mt-6 text-h2 font-medium leading-relaxed">
          마닐라 시티 오브 드림스 2대 럭셔리 호텔<br />
          <span class="font-bold">Nüwa 누와 호텔 / Nobu 노부 호텔</span>
        </h2>
        <p class="reveal mt-5 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-h1 font-extrabold">
          <span>2박/3박 숙박권</span>
          <img src="/assets/icon-discount-arrow.svg" alt="" class="h-[1.1em] w-[1.1em] shrink-0" />
          <span><span class="text-flame">80%</span> 파격 할인</span>
        </p>

        <div class="reveal mt-12 grid grid-cols-3 gap-1.5 md:gap-3">
          <img src={img("03_benefit01_nobu_hotel")} alt="누와 호텔 수영장" class="aspect-[0.94] w-full rounded-lg object-cover md:rounded-xl" />
          <img src={img("03_benefit01_forbes")} alt="Forbes Travel Guide — NUWA / NOBU HOTEL" class="aspect-[0.94] w-full rounded-lg object-cover md:rounded-xl" />
          <img src={img("03_benefit01_hotel")} alt="노부 호텔 객실" class="aspect-[0.94] w-full rounded-lg object-cover md:rounded-xl" />
        </div>

        <p class="mx-auto mt-12 max-w-[640px] text-left text-body">
          공항(NAIA)과 가까운 City of Dreams Manila(파라냐케)의 서로 다른 매력의 두 호텔.
          마닐라의 밤을 가장 ‘맛있게’ 즐길 수 있는 Nobu(노부) 호텔과 도심 속 가장 조용한 럭셔리로
          하루를 시작할 수 있는 Nüwa(누와) 호텔 중 2박 3일 / 3박 4일 머무실 호텔을 선택하실 수 있습니다.
        </p>
        <p class="mx-auto mt-6 max-w-[640px] text-left text-caption text-white/70">
          * 여행 일정에 따라 일부 호텔은 예약이 불가할 수 있습니다. 예약 가능 여부는 상품 문의를
          통해 부탁드립니다.
        </p>
      </div>
    </section>

    <!-- ─── 프로모션 참여 방법 ────────────────────────────────────── -->
    <section class="bg-white text-ink">
      <div class="mx-auto w-full max-w-[720px] px-5 py-24 md:px-10 md:py-40">
        <div class="text-center">
          <p class="reveal text-eyebrow font-bold">이렇게만 하시면 됩니다!</p>
          <h2 class="reveal mt-1 text-h1 font-extrabold">프로모션 참여 방법</h2>
        </div>
        <ol class="mt-14 md:mt-20">
          {
            steps.map((step, i) => (
              <li
                class:list={[
                  "reveal flex items-start gap-5 py-5 md:gap-8 md:py-6",
                  i > 0 && "border-t border-black/10",
                ]}
              >
                <img src={`/assets/${step.icon}.svg`} alt="" class="mt-1 h-8 w-8 shrink-0" />
                <div>
                  <p class="text-caption font-extrabold uppercase tracking-[0.18em] text-ink/45">
                    Step {i + 1}
                  </p>
                  <p class="mt-1 text-body" set:html={step.html} />
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- ─── 멜코클럽 멤버십 카드 ──────────────────────────────────── -->
    <section class="bg-ink">
      <div class="mx-auto w-full max-w-[720px] px-5 py-24 text-center md:px-10 md:py-40">
        <p class="reveal text-eyebrow font-bold text-flame">여기서 잠깐!</p>
        <h2 class="reveal mt-1 text-h1 font-extrabold">멜코클럽 멤버십 카드가 뭔가요?</h2>

        <div class="reveal relative mx-auto mt-14 w-full max-w-[268px] md:mt-20 md:max-w-[544px]">
          <img src={img("06_melco_card")} alt="멜코클럽 멤버십 카드" class="w-full" />
          <img
            src={img("06_melco_logo")}
            alt="MELCO CLUB"
            class="absolute left-1/2 top-1/2 w-[110%] max-w-none -translate-x-1/2 -translate-y-1/2"
          />
        </div>
        <p class="mx-auto mt-8 max-w-[640px] text-left text-body text-white/95">
